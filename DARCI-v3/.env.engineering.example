# CAD model providers
# CadCoder adapter endpoint (if using Darci.Python built-in adapter)
DARCI_CADCODER_URL=http://127.0.0.1:8000/cadcoder/generate
DARCI_CADCODER_API_KEY=
DARCI_KITTYCAD_BASE_URL=https://api.zoo.dev
DARCI_KITTYCAD_API_KEY=
DARCI_KITTYCAD_PATH=/v1/text-to-cad

# CadCoder adapter internals (Darci.Python)
CADCODER_PROVIDER=ollama
CADCODER_OLLAMA_URL=http://127.0.0.1:11434/api/generate
CADCODER_OLLAMA_MODEL=gemma2:9b
CADCODER_ADAPTER_API_KEY=

# Python toolchain
DARCI_PYTHON_PATH=python
DARCI_BUILD123D_ENABLED=false
DARCI_MUJOCO_ENABLED=false
DARCI_LIBEMG_ENABLED=false

# CLI tools
DARCI_CALCULIX_PATH=
DARCI_KICAD_CLI_PATH=
DARCI_ROS2_CLI_PATH=

# Optional API bridges
DARCI_KICAD_MCP_URL=http://127.0.0.1:3333
DARCI_KICAD_MCP_API_KEY=
DARCI_ROSCRIBE_URL=http://127.0.0.1:9001
DARCI_ROSCRIBE_API_KEY=

# Optional hardware bindings
DARCI_OPENBCI_PORT=
